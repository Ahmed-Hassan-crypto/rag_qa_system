# Google Gemini API Key (required)
GOOGLE_API_KEY=

# Embedding Model (optional, defaults to all-mpnet-base-v2)
EMBEDDING_MODEL=all-mpnet-base-v2

# LLM Model (optional, defaults to gemini-2.0-flash)
LLM_MODEL=gemini-2.5-flash

# LLM Temperature (optional, defaults to 0.0)
LLM_TEMPERATURE=0.0

# ChromaDB Path (optional)
CHROMA_PATH=chroma_db

# Chunking Settings (optional)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retriever Top-K (optional)
RETRIEVER_K=5

# Server Settings (optional)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Debug Mode (optional)
DEBUG=false
